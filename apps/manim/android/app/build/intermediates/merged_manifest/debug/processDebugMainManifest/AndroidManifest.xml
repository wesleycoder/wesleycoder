    android:versionName="1.0" >

    <uses-sdk
        android:minSdkVersion="24"
        android:targetSdkVersion="35" />

    <uses-permission android:name="android.permission.INTERNET" />

    <permission
        android:name="dev.guima.manim.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"
